<title>Artwork</title>

<link href="https://fonts.googleapis.com" rel="stylesheet">

<style>
:root {
  --bg:#121212;
  --card:#1e1e1e;
  --text:#ffffff;
  --accent:#ffce44;
  --border:#333;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family:'Varela Round',sans-serif;
  margin:0;
  padding:30px;
  text-align:center;
}

h1{
  color:var(--accent);
  font-family:'Fredoka One',cursive;
}

.artwork-image{
  width:100%;
  max-width:1000px;
  display:block;
  margin:30px auto;
  border:4px solid white;
  border-radius:20px;
}

.audio-wrapper{
  width:100%;
  max-width:760px;
  margin:30px auto;
  background:var(--card);
  border:4px solid var(--accent);
  border-radius:20px;
  overflow:hidden;
  box-shadow:8px 8px 0px white;
}

.audio-wrapper iframe{
  width:100%;
  border:none;
  display:block;
}

.back-btn{
  display:inline-block;
  margin-top:30px;
  padding:15px 30px;
  border:2px solid white;
  border-radius:25px;
  color:white;
  text-decoration:none;
  font-family:'Fredoka One',cursive;
}

.back-btn:hover{
  background:rgba(255,255,255,.15);
}
</style>

</head>

<body>

