<style>
  :root {
    --bg: #121212; --card: #1e1e1e; --text: #ffffff; --accent: #ffce44; --border: #333;
  }

  body { 
    background: var(--bg); color: var(--text); font-family: 'Varela Round', sans-serif; 
    margin: 0; padding: 0; min-height: 100vh; overflow-x: hidden;
  }

  /* FRONT PAGE / START OVERLAY */
  #start-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: #121212; z-index: 9999; display: flex;
    flex-direction: column; justify-content: center; align-items: center;
    color: white; text-align: center; padding: 20px;
  }
  
  #start-overlay h1 { 
    font-family: 'Fredoka One', cursive; font-size: clamp(2.5rem, 8vw, 4rem); 
    color: var(--accent); margin: 0 0 20px 0; text-shadow: 4px 4px 0px #000;
  }

  .front-statement {
    max-width: 650px; background: var(--card); padding: 30px; border-radius: 25px;
    border: 4px solid var(--accent); line-height: 1.6; font-size: 1.1rem;
    box-shadow: 8px 8px 0px white; margin-bottom: 30px;
  }

  .start-btn {
    padding: 20px 50px; font-size: 1.5rem; background: var(--accent);
    color: #000; border: 4px solid #000; border-radius: 50px;
    font-family: 'Fredoka One', cursive; cursor: pointer;
    box-shadow: 6px 6px 0px white; transition: 0.3s;
  }
  .start-btn:hover { transform: scale(1.05); filter: brightness(1.1); }

.enlarge-btn {
  text-decoration: none;
}

  /* GALLERY CONTENT */
  #main-content { display: flex; flex-direction: column; align-items: center; padding: 20px; }

  header h1 { font-family: 'Fredoka One', cursive; font-size: clamp(2rem, 6vw, 3rem); color: var(--accent); text-shadow: 3px 3px 0px #000; margin-top: 20px; }

  /* AUDIO WRAPPERS */
  .audio-wrapper {
    width: 100%; max-width: 760px; margin: 20px auto 40px auto;
    background: var(--card); border: 4px solid var(--accent);
    border-radius: 20px; overflow: hidden; box-shadow: 8px 8px 0px var(--text);
  }
  .audio-wrapper iframe { display: block; border: none; width: 100%; }

  .grid-container {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px; width: 100%; max-width: 1200px; margin-top: 20px;
  }

  .photo-tile {
    background: var(--card); border-radius: 25px; border: 5px solid var(--text);
    overflow: hidden; cursor: pointer; position: relative;
    box-shadow: 8px 8px 0px rgba(0,0,0,0.3); transition: transform 0.3s ease;
  }
  .photo-tile:hover { transform: translateY(-8px); border-color: var(--accent); }
  .photo-tile img { width: 100%; height: 500px; object-fit: cover; display: block; }

  /* SHARED STYLE FOR ENLARGE AND BACK BUTTONS */
  .btn-clear {
    background: transparent; 
    color: #ffffff;           
    border: 2px solid #ffffff; 
    border-radius: 20px;
    font-family: 'Fredoka One', cursive; 
    cursor: pointer;
    transition: 0.3s;
    text-transform: uppercase;
  }

  .btn-clear:hover {
    background: rgba(255, 255, 255, 0.2); 
    transform: scale(1.05);
  }

  /* Specific sizing for the Enlarge button inside tiles */
  .enlarge-btn {
    position: absolute; top: 15px; right: 15px; 
    padding: 8px 15px; font-size: 0.8rem; z-index: 10;
  }

  /* Specific sizing for the Back button at the bottom */
  .back-btn {
    padding: 12px 30px; font-size: 1rem; margin-top: 40px; margin-bottom: 80px;
  }

  .tile-info { max-height: 0; overflow: hidden; transition: max-height 0.5s ease; text-align: center; }
  .photo-tile.active .tile-info { max-height: 300px; padding: 25px; border-top: 3px dashed var(--border); }

  /* LIGHTBOX MODAL */
  #lightbox {
    display: none; position: fixed; z-index: 10000; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.9); justify-content: center; align-items: center; cursor: zoom-out;
  }
  #lightbox img { max-width: 90%; max-height: 90%; border: 4px solid white; border-radius: 10px; }
</style>
</head>
